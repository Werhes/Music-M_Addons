<?xml version="1.0" encoding="utf-8" ?>
<Window x:ConnectionId='1'
    x:Class="VkMiniPlayer.VkMiniPlayerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="MiniPlayerWnd">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== ВЕРХНЯЯ ПАНЕЛЬ С ЗАГОЛОВКОМ ===== -->
        <Grid x:ConnectionId='2'
            x:Name="TitleBar"
            Height="40"
            Background="Transparent"
            AutomationProperties.Name="Заголовок окна">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Иконка VK M -->
            <Image x:ConnectionId='13'
                x:Name="AppIcon"
                Width="20"
                Height="20"
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                AutomationProperties.Name="Иконка VK M" />

            <!-- Название VK M Miniplayer -->
            <TextBlock x:ConnectionId='14'
                x:Name="TitleText"
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Text="VK M Miniplayer"
                TextTrimming="CharacterEllipsis"
                AutomationProperties.Name="VK M Miniplayer" />

            <!-- Кнопка "Закрепить" (булавка) -->
            <Button x:ConnectionId='15'
                x:Name="PinButton"
                Grid.Column="2"
                Width="36"
                Height="36"
                Margin="0,0,4,0"
                Padding="0"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                                       
                AutomationProperties.Name="Закрепить окно поверх всех окон">
                <FontIcon x:ConnectionId='17'
                    x:Name="PinIcon"
                    FontSize="16"
                    Glyph="&#xE718;" />
            </Button>

            <!-- Кнопка "Закрыть" -->
            <Button x:ConnectionId='16'
                x:Name="CloseButton"
                Grid.Column="3"
                Width="46"
                Height="36"
                Padding="0"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                                         
                AutomationProperties.Name="Закрыть мини-плеер">
                <FontIcon
                    FontSize="14"
                    Glyph="&#xE8BB;" />
            </Button>
        </Grid>

        <!-- ===== ОСНОВНОЙ КОНТЕНТ ПЛЕЕРА ===== -->
        <Grid Grid.Row="1" Margin="16,8,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Обложка -->
            <Border x:ConnectionId='3'
                x:Name="CoverBorder"
                Width="200"
                Height="200"
                HorizontalAlignment="Center"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                AutomationProperties.Name="Обложка трека">
                <Grid>
                    <Image x:ConnectionId='11'
                        x:Name="CoverImage"
                        Opacity="0.0"
                        Stretch="UniformToFill"
                        AutomationProperties.Name="Обложка" />
                    <FontIcon x:ConnectionId='12'
                        x:Name="CoverNote"
                        FontSize="120"
                        Glyph="&#xEC4F;"
                        Visibility="Visible"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Иконка ноты" />
                </Grid>
            </Border>

            <!-- Название трека -->
            <ScrollViewer
                Grid.Row="1"
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Hidden"
                MaxWidth="280"
                AutomationProperties.Name="Название трека">
                <TextBlock x:ConnectionId='10'
                    x:Name="TrackName"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Не играет"
                    TextAlignment="Center"
                    TextTrimming="None"
                    TextWrapping="NoWrap"
                    AutomationProperties.Name="Название трека" />
            </ScrollViewer>

            <!-- Исполнитель -->
            <ScrollViewer
                Grid.Row="2"
                HorizontalAlignment="Center"
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Hidden"
                MaxWidth="280"
                AutomationProperties.Name="Исполнитель">
                <TextBlock x:ConnectionId='9'
                    x:Name="ArtistName"
                    FontSize="14"
                    Opacity="0.6"
                    Text=""
                    TextAlignment="Center"
                    TextTrimming="None"
                    TextWrapping="NoWrap"
                    AutomationProperties.Name="Исполнитель" />
            </ScrollViewer>

            <!-- Слайдер прогресса -->
            <Slider x:ConnectionId='4'
                x:Name="PositionSlider"
                Grid.Row="3"
                Margin="0,8,0,0"
                Minimum="0"
                StepFrequency="0.1"
                                                          
                AutomationProperties.Name="Прогресс воспроизведения" />

            <!-- Кнопки управления -->
            <StackPanel
                Grid.Row="4"
                Margin="0,8,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">

                <!-- Предыдущий трек -->
                <Button x:ConnectionId='5'
                    x:Name="PrevButton"
                    Width="40"
                    Height="40"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                                            
                    AutomationProperties.Name="Предыдущий трек">
                    <FontIcon
                        FontSize="18"
                        Glyph="&#xE892;" />
                </Button>

                <!-- Play/Pause -->
                <Button x:ConnectionId='6'
                    x:Name="PlayPauseButton"
                    Width="48"
                    Height="48"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                                                 
                    AutomationProperties.Name="Воспроизвести / Пауза">
                    <FontIcon x:ConnectionId='8'
                        x:Name="PlayPauseIcon"
                        FontSize="24"
                        Glyph="&#xE768;" />
                </Button>

                <!-- Следующий трек -->
                <Button x:ConnectionId='7'
                    x:Name="NextButton"
                    Width="40"
                    Height="40"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                                            
                    AutomationProperties.Name="Следующий трек">
                    <FontIcon
                        FontSize="18"
                        Glyph="&#xE893;" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

